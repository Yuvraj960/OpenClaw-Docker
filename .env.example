# ============================================================
# OpenClaw  —  Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values below.
# NEVER commit .env to Git — it contains secrets.
# ============================================================

# ── Gateway token ───────────────────────────────────────────
# Used to authenticate the web dashboard.
# Generate a secure random value, e.g.:
#   PowerShell: [System.Web.Security.Membership]::GeneratePassword(32,4)
#   Or just type any long random string you'll remember.
OPENCLAW_GATEWAY_TOKEN=change_me_to_a_long_random_string_here

# ── Primary AI model (Ollama) ────────────────────────────────
# Format: ollama/<model_name>
# Must match a model you have already pulled in Ollama.
# Examples:
#   ollama/llama3.2:latest
#   ollama/qwen2.5-coder:7b
#   ollama/mistral:latest
#   ollama/deepseek-r1:8b
OPENCLAW_PRIMARY_MODEL=ollama/gpt-oss:20b

# ── Optional: Subagent / fast model ─────────────────────────
# A smaller/faster model used for parallel subtasks.
# Can be the same as primary if you only have one model.
OPENCLAW_SUBAGENT_MODEL=ollama/gemma3:12b

# ── Telegram bot (optional) ─────────────────────────────────
# Get this from @BotFather on Telegram.
# Leave blank if you do not want Telegram integration.
TELEGRAM_BOT_TOKEN=

# ── Brave Search (optional, free tier: 2000 queries/month) ──
# Get a free key at: https://brave.com/search/api/
# Leave blank to disable web search.
BRAVE_SEARCH_API_KEY=

# ── Workspace path ──────────────────────────────────────────
# Folder inside the container where the agent reads/writes files.
# Default is fine for most users.
OPENCLAW_WORKSPACE=/home/node/workspace
